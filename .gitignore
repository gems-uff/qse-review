# PDFs – typically large; store externally and reference via DVC or similar
papers/*.pdf

# Python environment
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/

# Intermediate generated data (can be regenerated by running the pipeline)
data/extracted/
data/classifications/

# Keep the output directory (histograms, CSVs) under version control
!data/output/
!data/output/.gitkeep

# OS / editor artefacts
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Env files (may contain API keys)
.env
